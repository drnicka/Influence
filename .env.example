# Voice (local-first fork) — copy to .env and adjust.
# Everything works with no .env at all: API on 3001, data in ./data, single-user
# until the first member registers.

# API server port. The Vite dev proxy reads the same variable, so one value
# keeps client and server aligned.
VOICE_PORT=3001

# Ballot/history/rounds/members/rooms storage
VOICE_DATA_DIR=./data

# CORS allowed origin (tighten beyond localhost when exposing on a network)
VOICE_CORS_ORIGIN=*

# ── Router (agents' ballot transport over the local network) ─────────────────
# Leave unset for a single local instance — agents can POST /api/ballots
# directly with a member key. Configure when running a local network of
# instances federating rooms through a relay hub.

# VOICE_ROUTER_URL=http://localhost:3001/router
# VOICE_INSTANCE_ID=local-mac
# VOICE_ROUTER_TOKEN=
# VOICE_ROUTER_HMAC_KEY=
# VOICE_ROUTER_ADMIN_TOKEN=
# VOICE_ROUTER_PULL_LIMIT=50
# VOICE_INTERNAL_ROUTER_KEY=

# Enable the poller loop (pull + ingest envelopes from the router)
# VOICE_ROUTER_POLL_ENABLED=1
# VOICE_ROUTER_POLL_INTERVAL_MS=5000

# Auto-create a binary execution ballot when a QV ballot completes
VOICE_AUTO_EXECUTION_BALLOTS=0
