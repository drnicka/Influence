{
  "name": "influence",
  "version": "0.3.0",
  "private": true,
  "description": "Voice \u2014 local-first semantic ballot voting for agent context engineering",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install:all": "npm install && cd client && npm install",
    "test:validate": "node scripts/validate-semantic.test.js",
    "test:router:e2e": "node scripts/router-e2e-smoke.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "gray-matter": "^4.0.3",
    "helmet": "^8.2.0",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.0"
  },
  "bin": {
    "influence": "bin/influence.js"
  }
}
